# ==============================
# 安全审计配置示例
# 复制本文件为 .env 后按需填写
# ==============================

# 扫描模式：full_repo 或 pr
ANALYSIS_SCOPE=full_repo

# 全仓扫描模式下的仓库展示名（可选）
REPO_NAME=my-repo

# 待扫描仓库的绝对路径
REPO_PATH=/absolute/path/to/repo

# 统一输出目录（可选）。设置后产物输出到该目录；留空则回退到仓库目录
OUTPUT_DIR=

# CWD目录文件路径（可选）。设置后优先使用该路径；留空则默认使用 auditengine/cwd_catalog.json
CWD_CATALOG_PATH=

# PR 模式参数（仅当 ANALYSIS_SCOPE=pr 时必填）
GITHUB_TOKEN=
GIT_URL=
PR_NUMBER=

# 是否启用分阶段流程（true/false）
USE_PHASED_ANALYSIS=true

# 误报过滤开关（true/false）
ENABLE_OPENCODE_FILTERING=true
ENABLE_HARD_EXCLUSIONS=true

# 需要排除的目录（逗号分隔）
EXCLUDE_DIRECTORIES=tests,docs,bin,test,example,examples

# 可选的额外提示词文件
# 误报过滤补充指令文件路径
FALSE_POSITIVE_FILTERING_INSTRUCTIONS=
# 安全扫描补充指令文件路径，分阶段扫描时无效
CUSTOM_SECURITY_SCAN_INSTRUCTIONS=

# OpenCode 调用使用的模型/供应商配置
MODEL_ID=gpt-5.3-codex
PROVIDER_ID=codez-gpt

# 会话与子进程超时（秒）
DEFAULT_TIMEOUT_SECONDS=1200
SUBPROCESS_TIMEOUT=1200

# 分阶段并发度（代码内会限制在 [1,16]）
PHASE_PARALLELISM=4

# 重试/退避与 token 上限
DEFAULT_MAX_RETRIES=3
RATE_LIMIT_BACKOFF_MAX=30
PROMPT_TOKEN_LIMIT=16384

# OpenCode 服务端/客户端地址配置
# 若 OPENCODE_API_URL 为空，代码会回退到 http://127.0.0.1:<OPENCODE_PORT>
OPENCODE_API_URL=http://localhost:4097
OPENCODE_PORT=4097
OPENCODE_SERVER_BIN=opencode

# 运行时网络代理绕过列表
NO_PROXY=127.0.0.1,localhost
